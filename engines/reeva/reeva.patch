@@ -0,0 +1,56 @@
+package com.reevajs.reeva.test262
+
+import com.reevajs.reeva.Reeva
+import com.reevajs.reeva.core.Agent
+import com.reevajs.reeva.core.lifecycle.FileSourceInfo
+import com.reevajs.reeva.core.lifecycle.LiteralSourceInfo
+import com.reevajs.reeva.core.lifecycle.SourceInfo
+import com.reevajs.reeva.runtime.primitives.JSUndefined
+import java.io.File
+
+private data class CliOptions(
+    val isModule: Boolean,
+    val files: List<String>,
+)
+
+fun main(args: Array<String>) {
+    val options = parseArgs(args)
+
+    Agent.build().withActiveScope {
+        makeRealmAndInitializeExecutionEnvironment()
+
+        if (options.files.isNotEmpty()) {
+            options.files.forEach { runAndPrint(FileSourceInfo(File(it), isModule = options.isModule)) }
+            return@withActiveScope
+        }
+
+        while (true) {
+            print("> ")
+            val line = readLine() ?: break
+            if (line.isBlank()) continue
+            runAndPrint(LiteralSourceInfo("repl", line, options.isModule))
+        }
+    }
+}
+
+private fun parseArgs(args: Array<String>): CliOptions {
+    var isModule = false
+    val files = mutableListOf<String>()
+
+    for (arg in args) {
+        if (arg == "--module") {
+            isModule = true
+        } else {
+            files += arg
+        }
+    }
+
+    return CliOptions(isModule, files)
+}
+
+private fun runAndPrint(source: SourceInfo) {
+    val result = Reeva.execute(source)
+    if (result != null && result != JSUndefined)
+        println(result)
+    Agent.activeAgent.microtaskQueue.checkpoint()
+}
