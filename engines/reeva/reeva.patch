--- /dev/null
+++ b/src/test/kotlin/com/reevajs/reeva/test262/Main.kt
@@ -0,0 +1,55 @@
+package com.reevajs.reeva.test262
+
+import com.reevajs.reeva.Reeva
+import com.reevajs.reeva.core.Agent
+import com.reevajs.reeva.core.HostHooks
+import com.reevajs.reeva.core.Realm
+import com.reevajs.reeva.core.lifecycle.*
+import com.reevajs.reeva.runtime.AOs
+import com.reevajs.reeva.runtime.functions.JSBuiltinFunction
+import com.reevajs.reeva.runtime.global.JSConsoleProto
+import com.reevajs.reeva.runtime.objects.*
+import com.reevajs.reeva.runtime.primitives.JSUndefined
+import com.reevajs.reeva.utils.*
+import java.io.File
+
+fun main(args: Array<String>) {
+    var isModule = false
+    val files = mutableListOf<String>()
+    for (arg in args) when (arg) {
+        "-h", "--help" -> { System.err.println("Usage: reeva [-m|--module] [file.js ...]"); return }
+        "-m", "--module" -> isModule = true
+        else -> files += arg
+    }
+
+    Agent.build {
+        hostHooks = object : HostHooks() {
+            override fun createHostDefinedProperties(realm: Realm, globalObject: JSObject) {
+                super.createHostDefinedProperties(realm, globalObject)
+                AOs.definePropertyOrThrow(globalObject, "$262".key(),
+                    JS262Object.create(globalObject, realm).toDescriptor { +conf; -enum; +writ })
+                AOs.definePropertyOrThrow(globalObject, "print".key(),
+                    Descriptor(JSBuiltinFunction.create("print", 1, JSConsoleProto::log), attrs { +conf; +writ }))
+            }
+        }
+    }.withActiveScope {
+        makeRealmAndInitializeExecutionEnvironment()
+
+        if (files.isNotEmpty()) {
+            files.forEach { exec(FileSourceInfo(File(it), isModule = isModule || it.endsWith(".mjs"))) }
+            return@withActiveScope
+        }
+
+        while (true) {
+            print("> ")
+            val line = readLine() ?: break
+            if (line.isBlank()) continue
+            exec(LiteralSourceInfo("repl", line, isModule))
+        }
+    }
+}
+
+private fun exec(source: SourceInfo) {
+    Reeva.execute(source)?.let { if (it != JSUndefined) println(it) }
+    Agent.activeAgent.microtaskQueue.checkpoint()
+}
