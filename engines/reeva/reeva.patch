+    private fun formatRuntimeError(cause: JSValue): String {
+        if (cause is JSObject && cause.hasProperty("message".key())) {
+            val ctor = cause.get("constructor")
+            val name = if (ctor is JSFunction) ctor.get("name").toString() else null
+            val message = cause.get("message").toString()
+
+            if (!name.isNullOrBlank()) {
+                return if (message.isBlank()) name else "$name: $message"
+            }
+        }
+
+        return cause.toString()
+    }
+
+    private fun formatThrowable(cause: Throwable): String {
